# Copy to .env.local and fill in. Next.js loads .env.local from this folder when you run pnpm dev/build.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: same pattern as mobile backend — bypasses RLS for orders (never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: mobile / external API clients send header x-api-key (must match). Website uses Supabase session cookies.
API_SECRET_KEY=

PAYSTACK_SECRET_KEY=sk_test_xxx
